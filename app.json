          "location",
          "fetch",
          "remote-notification"
        ]
      },
      "bundleIdentifier": "com.pashagr.mobileapplication",
      "config": {
        "googleMapsApiKey": "AIzaSyA8Gs9cDcKHTrC83D_GaBVeP2yCfA_Doxs"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00015a"
      },
      "package": "com.pashagr.mobileapplication",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "config": {
