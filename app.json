          "apiKey": "AIzaSyA8Gs9cDcKHTrC83D_GaBVeP2yCfA_Doxs"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "501e3c68-469f-4a30-8d92-7583636391bd"
      }
    },
    "owner": "pashagr",
    "runtimeVersion": "1.0.0",
    "updates": {
